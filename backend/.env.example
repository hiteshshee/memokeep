# ===== Server =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===== Database (MongoDB Atlas) =====
# Get this from MongoDB Atlas -> Connect -> Drivers
MONGO_URI=mongodb://127.0.0.1:27017/memokeep

# ===== JWT =====
# Use long random strings. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== Cloudinary (file/image storage) =====
# Get these from Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
